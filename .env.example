# =======================================
# OneClick-Host Environment Variables
# =======================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in all values marked with <CHANGE_ME>
# 3. NEVER commit .env to git

# ──────────────────────────────────────────────
# SECTION 1: PostgreSQL Database
# ──────────────────────────────────────────────
# LOCAL DEV: "db" (Docker service name, internal DNS)
# AWS PROD:  Your RDS endpoint (e.g. mydb.xxxx.ap-southeast-1.rds.amazonaws.com)
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=oneclickhost
POSTGRES_USER=oneclick
POSTGRES_PASSWORD=<CHANGE_ME>

# ──────────────────────────────────────────────
# SECTION 2: ASP.NET Core API
# ──────────────────────────────────────────────
# LOCAL DEV: Development
# AWS PROD:  Production
ASPNETCORE_ENVIRONMENT=Development

# LOCAL DEV: Host=db;...  (uses Docker service name)
# AWS PROD:  Host=<RDS_ENDPOINT>;Port=5432;Database=oneclickhost;Username=oneclick;Password=<CHANGE_ME>;SslMode=Require
CONNECTION_STRING=Host=db;Port=5432;Database=oneclickhost;Username=oneclick;Password=<CHANGE_ME>

# JWT Settings — MUST be changed in production
# Minimum 32 characters. Generate with: openssl rand -base64 32
JWT_SECRET=<CHANGE_ME_min_32_chars>
JWT_ISSUER=oneclick-host
JWT_AUDIENCE=oneclick-host-client
JWT_EXPIRY_HOURS=24

# ISSUE #10 FIX: CORS — comma-separated list of allowed origins
# LOCAL DEV: http://localhost:3000
# AWS PROD:  https://yourdomain.com  (no trailing slash)
CORS_ORIGINS=http://localhost:3000

# ──────────────────────────────────────────────
# SECTION 3: Python Worker
# ──────────────────────────────────────────────
# How often the worker polls for new jobs (seconds)
WORKER_POLL_INTERVAL=5

# Max time allowed for a single Docker build (seconds). 900 = 15 minutes
WORKER_BUILD_TIMEOUT=900

# LOCAL DEV: unix:///var/run/docker.sock
# AWS PROD:  unix:///var/run/docker.sock  (same — Worker always talks to EC2's Docker Engine)
DOCKER_HOST=unix:///var/run/docker.sock

# Temporary directory for cloning repos during builds
WORKSPACE_DIR=/tmp/oneclick-workspace

# Per-container resource limits to prevent a user from consuming all EC2 resources
CONTAINER_MEMORY_LIMIT=256m
CONTAINER_CPU_LIMIT=0.5

# ──────────────────────────────────────────────
# SECTION 4: Frontend Dashboard (Next.js)
# ──────────────────────────────────────────────
# LOCAL DEV: http://localhost:5000/api  (direct access)
# AWS PROD:  https://yourdomain.com/api (goes through Traefik, same domain, different path)
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# ──────────────────────────────────────────────
# SECTION 5: Traefik Reverse Proxy
# ──────────────────────────────────────────────
# LOCAL DEV: localhost
# AWS PROD:  yourdomain.com  (Traefik will route *.yourdomain.com to user containers)
TRAEFIK_DOMAIN=localhost

# ──────────────────────────────────────────────
# SECTION 6: Docker Compose / Networking
# ──────────────────────────────────────────────
# Lock the Compose project name so the network is always named consistently.
# Network = <COMPOSE_PROJECT_NAME>_oneclick-net
# Worker reads TRAEFIK_NETWORK to join user containers to the correct network.
COMPOSE_PROJECT_NAME=oneclick
TRAEFIK_NETWORK=oneclick_oneclick-net
